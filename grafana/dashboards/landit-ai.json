{
  "uid": "landit-ai",
  "title": "Landit AI",
  "description": "FastAPI AI worker의 endpoint, Python process·GC, 로그를 환경별로 확인합니다.",
  "tags": ["landit", "observability", "ai", "fastapi"],
  "timezone": "Asia/Seoul",
  "schemaVersion": 41,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": [
    {"name": "environment", "label": "환경", "type": "custom", "query": "prod,develop", "current": {"text": "prod", "value": "prod"}, "options": [{"text": "prod", "value": "prod", "selected": true}, {"text": "develop", "value": "develop", "selected": false}], "includeAll": false, "multi": false, "hide": 0},
    {"name": "endpoint", "label": "Endpoint", "type": "query", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "definition": "label_values(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}, http_route)", "query": {"query": "label_values(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}, http_route)", "refId": "PrometheusVariableQueryEditor-VariableQuery"}, "current": {"text": "All", "value": "$__all"}, "includeAll": true, "allValue": ".*", "multi": true, "hide": 0},
    {"name": "log_search", "label": "로그 본문 검색", "type": "textbox", "query": "", "current": {"text": "", "value": ""}, "hide": 0}
  ]},
  "panels": [
    {"id": 1, "type": "row", "title": "HTTP", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {"id": 2, "type": "stat", "title": "TPS", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value"}, "targets": [{"refId": "A", "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_route=~\"$endpoint\"}[$__rate_interval]))"}]},
    {"id": 3, "type": "stat", "title": "선택 기간 요청 수", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 4, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value"}, "targets": [{"refId": "A", "expr": "sum(increase(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_route=~\"$endpoint\"}[$__range]))"}]},
    {"id": 4, "type": "stat", "title": "5xx 오류율", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 8, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background"}, "targets": [{"refId": "A", "expr": "100 * sum(rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_route=~\"$endpoint\",http_response_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_route=~\"$endpoint\"}[$__rate_interval])), 0.000001)"}]},
    {"id": 5, "type": "timeseries", "title": "Endpoint별 TPS", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_route=~\"$endpoint\"}[$__rate_interval]))", "legendFormat": "{{http_route}}"}]},
    {"id": 6, "type": "timeseries", "title": "상태 코드별 요청", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 8, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_route=~\"$endpoint\"}[$__rate_interval]))", "legendFormat": "{{http_response_status_code}}"}]},
    {"id": 7, "type": "timeseries", "title": "Endpoint별 응답시간", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 14, "w": 24, "h": 8}, "fieldConfig": {"defaults": {"unit": "ms", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 8, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "1000 * histogram_quantile(0.50, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_route=~\"$endpoint\"}[$__rate_interval])))", "legendFormat": "P50 {{http_route}}"}, {"refId": "B", "expr": "1000 * histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_route=~\"$endpoint\"}[$__rate_interval])))", "legendFormat": "P95 {{http_route}}"}, {"refId": "C", "expr": "1000 * histogram_quantile(0.99, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_route=~\"$endpoint\"}[$__rate_interval])))", "legendFormat": "P99 {{http_route}}"}]},
    {"id": 8, "type": "row", "title": "Python runtime", "gridPos": {"x": 0, "y": 22, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {"id": 9, "type": "timeseries", "title": "Process CPU 사용률", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 23, "w": 8, "h": 8}, "fieldConfig": {"defaults": {"unit": "percentunit", "custom": {"drawStyle": "line", "fillOpacity": 12, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "process_cpu_utilization_ratio{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}", "legendFormat": "cpu"}]},
    {"id": 10, "type": "timeseries", "title": "Process 메모리", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 8, "y": 23, "w": 8, "h": 8}, "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "fillOpacity": 12, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "process_memory_usage_bytes{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}", "legendFormat": "physical"}, {"refId": "B", "expr": "process_memory_virtual_bytes{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}", "legendFormat": "virtual"}]},
    {"id": 11, "type": "timeseries", "title": "Process thread", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 16, "y": 23, "w": 8, "h": 8}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "fillOpacity": 12, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "process_thread_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}", "legendFormat": "threads"}]},
    {"id": 12, "type": "timeseries", "title": "CPython GC", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 31, "w": 24, "h": 8}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum by (generation) (rate(cpython_gc_collections_total{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "collections gen {{generation}}"}, {"refId": "B", "expr": "sum by (generation) (rate(cpython_gc_collected_objects_total{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "collected gen {{generation}}"}, {"refId": "C", "expr": "sum by (generation) (rate(cpython_gc_uncollectable_objects_total{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "uncollectable gen {{generation}}"}]},
    {"id": 13, "type": "row", "title": "로그", "gridPos": {"x": 0, "y": 39, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {"id": 14, "type": "timeseries", "title": "로그·에러 로그 발생량", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 0, "y": 40, "w": 24, "h": 7}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "fillOpacity": 60}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum(count_over_time({project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/worker\"}[$__interval]))", "legendFormat": "all"}, {"refId": "B", "expr": "sum(count_over_time({project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/worker\"} |~ \"(?i)(error|exception|traceback|critical|fatal)\" [$__interval]))", "legendFormat": "error"}]},
    {"id": 15, "type": "logs", "title": "전체 로그", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 0, "y": 47, "w": 12, "h": 12}, "options": {"dedupStrategy": "none", "enableLogDetails": true, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true}, "targets": [{"refId": "A", "expr": "{project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/worker\"} |~ \"$log_search\""}]},
    {"id": 16, "type": "logs", "title": "에러 로그", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 12, "y": 47, "w": 12, "h": 12}, "options": {"dedupStrategy": "none", "enableLogDetails": true, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true}, "targets": [{"refId": "A", "expr": "{project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/worker\"} |~ \"(?i)(error|exception|traceback|critical|fatal)\""}]},
    {"id": 17, "type": "logs", "title": "피드백 후보 fallback 로그", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 0, "y": 59, "w": 12, "h": 12}, "timeFrom": "3d", "options": {"dedupStrategy": "none", "enableLogDetails": true, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true}, "targets": [{"refId": "A", "expr": "{project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/worker\"} |= \"workflow=message_feedback_candidate_fallback\""}]},
    {"id": 18, "type": "logs", "title": "피드백 생성 실패 로그", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 12, "y": 59, "w": 12, "h": 12}, "timeFrom": "3d", "options": {"dedupStrategy": "none", "enableLogDetails": true, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true}, "targets": [{"refId": "A", "expr": "{project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/worker\"} |= \"workflow=message_feedback_failed\""}]}
  ]
}
