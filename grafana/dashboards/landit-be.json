{
  "uid": "landit-be",
  "title": "Landit BE",
  "description": "Spring Boot API의 endpoint, JVM, 로그를 환경별로 확인합니다.",
  "tags": ["landit", "observability", "be", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": [
    {"name": "environment", "label": "환경", "type": "custom", "query": "prod,develop", "current": {"text": "prod", "value": "prod"}, "options": [{"text": "prod", "value": "prod", "selected": true}, {"text": "develop", "value": "develop", "selected": false}], "includeAll": false, "multi": false, "hide": 0},
    {"name": "endpoint", "label": "Endpoint", "type": "query", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "definition": "label_values(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}, uri)", "query": {"query": "label_values(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}, uri)", "refId": "PrometheusVariableQueryEditor-VariableQuery"}, "current": {"text": "All", "value": "$__all"}, "includeAll": true, "allValue": ".*", "multi": true, "hide": 0},
    {"name": "log_search", "label": "로그 본문 검색", "type": "textbox", "query": "", "current": {"text": "", "value": ""}, "hide": 0}
  ]},
  "panels": [
    {"id": 1, "type": "row", "title": "HTTP", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {"id": 2, "type": "stat", "title": "TPS", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value"}, "targets": [{"refId": "A", "expr": "sum(rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\",uri=~\"$endpoint\"}[$__rate_interval]))"}]},
    {"id": 3, "type": "stat", "title": "선택 기간 요청 수", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 4, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value"}, "targets": [{"refId": "A", "expr": "sum(increase(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\",uri=~\"$endpoint\"}[$__range]))"}]},
    {"id": 4, "type": "stat", "title": "5xx 오류율", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 8, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background"}, "targets": [{"refId": "A", "expr": "100 * sum(rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\",uri=~\"$endpoint\",status=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\",uri=~\"$endpoint\"}[$__rate_interval])), 0.000001)"}]},
    {"id": 5, "type": "timeseries", "title": "Endpoint별 TPS", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum by (uri) (rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\",uri=~\"$endpoint\"}[$__rate_interval]))", "legendFormat": "{{uri}}"}]},
    {"id": 6, "type": "timeseries", "title": "상태 코드별 요청", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 8, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum by (status) (rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\",uri=~\"$endpoint\"}[$__rate_interval]))", "legendFormat": "{{status}}"}]},
    {"id": 7, "type": "timeseries", "title": "Endpoint별 응답시간", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 14, "w": 24, "h": 8}, "fieldConfig": {"defaults": {"unit": "ms", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 8, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "histogram_quantile(0.50, sum by (le, uri) (rate(http_server_requests_milliseconds_bucket{service_name=\"landit-be\",deployment_environment_name=\"$environment\",uri=~\"$endpoint\"}[$__rate_interval])))", "legendFormat": "P50 {{uri}}"}, {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_milliseconds_bucket{service_name=\"landit-be\",deployment_environment_name=\"$environment\",uri=~\"$endpoint\"}[$__rate_interval])))", "legendFormat": "P95 {{uri}}"}, {"refId": "C", "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_milliseconds_bucket{service_name=\"landit-be\",deployment_environment_name=\"$environment\",uri=~\"$endpoint\"}[$__rate_interval])))", "legendFormat": "P99 {{uri}}"}]},
    {"id": 8, "type": "row", "title": "JVM", "gridPos": {"x": 0, "y": 22, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {"id": 9, "type": "timeseries", "title": "Heap 사용량과 최대값", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 23, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum(jvm_memory_used_bytes{service_name=\"landit-be\",deployment_environment_name=\"$environment\",area=\"heap\"})", "legendFormat": "used"}, {"refId": "B", "expr": "sum(jvm_memory_max_bytes{service_name=\"landit-be\",deployment_environment_name=\"$environment\",area=\"heap\"})", "legendFormat": "max"}, {"refId": "C", "expr": "sum(jvm_memory_used_bytes{service_name=\"landit-be\",deployment_environment_name=\"$environment\",area=\"nonheap\"})", "legendFormat": "non-heap used"}]},
    {"id": 10, "type": "stat", "title": "Heap 사용률", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 12, "y": 23, "w": 4, "h": 8}, "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 70}, {"color": "red", "value": 85}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background"}, "targets": [{"refId": "A", "expr": "100 * sum(jvm_memory_used_bytes{service_name=\"landit-be\",deployment_environment_name=\"$environment\",area=\"heap\"}) / clamp_min(sum(jvm_memory_max_bytes{service_name=\"landit-be\",deployment_environment_name=\"$environment\",area=\"heap\"}), 1)"}]},
    {"id": 11, "type": "timeseries", "title": "GC pause와 실행 횟수", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 16, "y": 23, "w": 8, "h": 8}, "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum(rate(jvm_gc_pause_milliseconds_sum{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "pause ms/s"}, {"refId": "B", "expr": "sum(rate(jvm_gc_pause_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "collections/s"}]},
    {"id": 12, "type": "timeseries", "title": "JVM Thread", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 31, "w": 12, "h": 7}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "jvm_threads_live{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}", "legendFormat": "live"}, {"refId": "B", "expr": "jvm_threads_daemon{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}", "legendFormat": "daemon"}, {"refId": "C", "expr": "jvm_threads_peak{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}", "legendFormat": "peak"}]},
    {"id": 13, "type": "timeseries", "title": "GC allocation·promotion rate", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 12, "y": 31, "w": 12, "h": 7}, "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum(rate(jvm_gc_memory_allocated_bytes_total{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "allocated"}, {"refId": "B", "expr": "sum(rate(jvm_gc_memory_promoted_bytes_total{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "promoted"}]},
    {"id": 14, "type": "row", "title": "로그", "gridPos": {"x": 0, "y": 38, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {"id": 15, "type": "timeseries", "title": "로그·에러 로그 발생량", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 0, "y": 39, "w": 24, "h": 7}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "fillOpacity": 60}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum(count_over_time({project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/api\"}[$__interval]))", "legendFormat": "all"}, {"refId": "B", "expr": "sum(count_over_time({project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/api\"} |~ \"(?i)(error|exception|traceback|critical|fatal)\" [$__interval]))", "legendFormat": "error"}]},
    {"id": 16, "type": "logs", "title": "전체 로그", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 0, "y": 46, "w": 12, "h": 12}, "options": {"dedupStrategy": "none", "enableLogDetails": true, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true}, "targets": [{"refId": "A", "expr": "{project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/api\"} |~ \"$log_search\""}]},
    {"id": 17, "type": "logs", "title": "에러 로그", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 12, "y": 46, "w": 12, "h": 12}, "options": {"dedupStrategy": "none", "enableLogDetails": true, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true}, "targets": [{"refId": "A", "expr": "{project=\"landit\",environment=\"$environment\",aws_log_group=\"/landit/$environment/api\"} |~ \"(?i)(error|exception|traceback|critical|fatal)\""}]}
  ]
}
