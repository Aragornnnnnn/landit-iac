{
  "uid": "landit-overview",
  "title": "Landit Overview",
  "description": "BE·AI의 요청 상태와 로그를 환경별로 확인하는 운영 시작 화면입니다.",
  "tags": ["landit", "observability", "overview"],
  "timezone": "Asia/Seoul",
  "schemaVersion": 41,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "links": [
    {"title": "BE 상세 보기", "url": "/d/landit-be/landit-be?var-environment=${environment}", "includeVars": true, "keepTime": true},
    {"title": "AI 상세 보기", "url": "/d/landit-ai/landit-ai?var-environment=${environment}", "includeVars": true, "keepTime": true}
  ],
  "templating": {
    "list": [
      {"name": "environment", "label": "환경", "type": "custom", "query": "prod,develop", "current": {"text": "prod", "value": "prod"}, "options": [{"text": "prod", "value": "prod", "selected": true}, {"text": "develop", "value": "develop", "selected": false}], "includeAll": false, "multi": false, "hide": 0},
      {"name": "service", "label": "로그 서비스", "type": "custom", "query": "All : api|worker,BE : api,AI : worker", "current": {"text": "All", "value": "api|worker"}, "includeAll": false, "multi": false, "hide": 0},
      {"name": "log_search", "label": "로그 본문 검색", "type": "textbox", "query": "", "current": {"text": "", "value": ""}, "hide": 0}
    ]
  },
  "panels": [
    {"id": 1, "type": "row", "title": "요청 상태", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {"id": 2, "type": "stat", "title": "전체 TPS", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto", "textMode": "auto", "colorMode": "value"}, "targets": [{"refId": "A", "expr": "sum(rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "BE"}, {"refId": "B", "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "AI"}]},
    {"id": 3, "type": "stat", "title": "BE TPS", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 4, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value"}, "targets": [{"refId": "A", "expr": "sum(rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}[$__rate_interval]))"}]},
    {"id": 4, "type": "stat", "title": "AI TPS", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 8, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value"}, "targets": [{"refId": "A", "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}[$__rate_interval]))"}]},
    {"id": 5, "type": "stat", "title": "BE 5xx 오류율", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 12, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background"}, "targets": [{"refId": "A", "expr": "(100 * sum(rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\",status=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}[$__rate_interval])), 0.000001)) or vector(0)"}]},
    {"id": 6, "type": "stat", "title": "AI 5xx 오류율", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 16, "y": 1, "w": 4, "h": 5}, "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []}, "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background"}, "targets": [{"refId": "A", "expr": "(100 * sum(rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\",http_response_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}[$__rate_interval])), 0.000001)) or vector(0)"}]},
    {"id": 7, "type": "timeseries", "title": "서비스별 TPS", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 12, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum(rate(http_server_requests_milliseconds_count{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "BE"}, {"refId": "B", "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}[$__rate_interval]))", "legendFormat": "AI"}]},
    {"id": 8, "type": "timeseries", "title": "P95 응답시간", "datasource": {"uid": "grafanacloud-prom", "type": "prometheus"}, "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "ms", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 12, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_milliseconds_bucket{service_name=\"landit-be\",deployment_environment_name=\"$environment\"}[$__rate_interval])))", "legendFormat": "BE"}, {"refId": "B", "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"landit-ai\",deployment_environment_name=\"$environment\"}[$__rate_interval])))", "legendFormat": "AI"}]},
    {"id": 9, "type": "row", "title": "로그", "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {"id": 10, "type": "timeseries", "title": "로그 발생량", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 0, "y": 15, "w": 12, "h": 7}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "fillOpacity": 65}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum by (aws_log_group) (count_over_time({project=\"landit\",environment=\"$environment\",aws_log_group=~\"/landit/$environment/(${service:raw})\"}[$__interval]))", "legendFormat": "{{aws_log_group}}"}]},
    {"id": 11, "type": "timeseries", "title": "에러 로그 발생량", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 12, "y": 15, "w": 12, "h": 7}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "fillOpacity": 65}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"refId": "A", "expr": "sum(count_over_time({project=\"landit\",environment=\"$environment\",aws_log_group=~\"/landit/$environment/(${service:raw})\"} |~ \"(?i)(error|exception|traceback|critical|fatal)\" [$__interval])) or vector(0)", "legendFormat": "error"}]},
    {"id": 12, "type": "logs", "title": "전체 로그", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 0, "y": 22, "w": 12, "h": 12}, "options": {"dedupStrategy": "none", "enableLogDetails": true, "showCommonLabels": false, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true}, "targets": [{"refId": "A", "expr": "{project=\"landit\",environment=\"$environment\",aws_log_group=~\"/landit/$environment/(${service:raw})\"} |~ \"$log_search\""}]},
    {"id": 13, "type": "logs", "title": "에러 로그", "datasource": {"uid": "grafanacloud-logs", "type": "loki"}, "gridPos": {"x": 12, "y": 22, "w": 12, "h": 12}, "options": {"dedupStrategy": "none", "enableLogDetails": true, "showCommonLabels": false, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true}, "targets": [{"refId": "A", "expr": "{project=\"landit\",environment=\"$environment\",aws_log_group=~\"/landit/$environment/(${service:raw})\"} |~ \"(?i)(error|exception|traceback|critical|fatal)\""}]}
  ]
}
